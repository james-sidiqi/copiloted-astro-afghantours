---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
}
const { eyebrow, title, subtitle, centered = false } = Astro.props;
const alignClass = centered ? 'text-center items-center' : 'text-left items-start';
---

<div class={`flex flex-col gap-2 ${alignClass}`}>
  {eyebrow && (
    <span class="text-xs font-semibold uppercase tracking-[0.12em] text-[#b88a2a]">
      {eyebrow}
    </span>
  )}
  <h2 class="font-display text-3xl sm:text-4xl font-bold text-[#1e3a5f] leading-tight">
    {title}
  </h2>
  {subtitle && (
    <p class={`text-base text-[rgba(15,23,42,0.65)] leading-relaxed ${centered ? 'max-w-xl' : 'max-w-2xl'}`}>
      {subtitle}
    </p>
  )}
</div>
