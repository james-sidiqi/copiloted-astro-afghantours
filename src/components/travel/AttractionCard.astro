---
interface Props {
  attraction: import('@lib/types/view-models').Attraction;
}
const { attraction } = Astro.props;
---

<article class="group bg-white rounded-[14px] shadow-[0_2px_16px_0_rgba(0,0,0,0.08)] hover:shadow-[0_10px_30px_rgba(15,23,42,0.08)] transition-shadow duration-300 overflow-hidden flex flex-col">
  <!-- Image -->
  <a href={`/attractions/${attraction.slug}`} class="block overflow-hidden aspect-[4/3] bg-gray-100 shrink-0">
    {attraction.thumbnailPath
      ? <img
          src={attraction.thumbnailPath}
          alt={attraction.name}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      : <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center text-primary-500 opacity-50">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
    }
  </a>

  <!-- Body -->
  <div class="flex flex-col flex-1 p-5 gap-2">
    <!-- Category badge -->
    {attraction.category && (
      <span class="self-start text-xs font-semibold px-2.5 py-0.5 rounded-full bg-primary-50 text-[#1f4aa8]">
        {attraction.category}
      </span>
    )}

    <a href={`/attractions/${attraction.slug}`} class="block">
      <h3 class="font-display text-base font-semibold text-[#1e3a5f] leading-snug group-hover:text-[#1f4aa8] transition-colors duration-150 line-clamp-2">
        {attraction.name}
      </h3>
    </a>

    <p class="text-sm text-[rgba(15,23,42,0.7)] leading-relaxed line-clamp-3 flex-1">
      {attraction.descShort}
    </p>

    <!-- Province label -->
    {attraction.province && (
      <p class="text-xs text-[rgba(15,23,42,0.5)] flex items-center gap-1 pt-1">
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        {attraction.province}
      </p>
    )}
  </div>
</article>
