---
interface Props {
  tour: import('@lib/types/view-models').Tour;
}
const { tour } = Astro.props;

const seasonColors: Record<string, string> = {
  Spring: 'bg-green-100 text-green-800',
  Summer: 'bg-yellow-100 text-yellow-800',
  Autumn: 'bg-orange-100 text-orange-800',
  Fall:   'bg-orange-100 text-orange-800',
  Winter: 'bg-blue-100 text-blue-800',
};
const seasonClass = seasonColors[tour.season] ?? 'bg-gray-100 text-gray-700';
---

<article class="group bg-white rounded-[14px] shadow-[0_2px_16px_0_rgba(0,0,0,0.08)] hover:shadow-[0_10px_30px_rgba(15,23,42,0.08)] transition-shadow duration-300 overflow-hidden flex flex-col">
  <!-- Image -->
  <a href={`/tours/${tour.slug}`} class="block overflow-hidden aspect-[16/10] bg-gray-100 shrink-0">
    {tour.thumbnailImagePath
      ? <img
          src={tour.thumbnailImagePath}
          alt={tour.name}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      : <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center text-primary-500 opacity-50">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
    }
  </a>

  <!-- Body -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <!-- Season badge -->
    {tour.season && (
      <span class={`self-start text-xs font-semibold px-2.5 py-0.5 rounded-full ${seasonClass}`}>
        {tour.season}
      </span>
    )}

    <a href={`/tours/${tour.slug}`} class="block">
      <h3 class="font-display text-lg font-semibold text-[#1e3a5f] leading-snug group-hover:text-[#1f4aa8] transition-colors duration-150 line-clamp-2">
        {tour.name}
      </h3>
    </a>

    <p class="text-sm text-[rgba(15,23,42,0.7)] leading-relaxed line-clamp-3 flex-1">
      {tour.summary}
    </p>

    <!-- Meta row -->
    <div class="flex items-center justify-between pt-2 border-t border-gray-100 text-sm">
      <span class="font-semibold text-[#1f4aa8]">
        From <span class="text-base">${tour.priceFrom.toLocaleString()}</span>
      </span>
      <span class="text-[rgba(15,23,42,0.55)] flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        {tour.durationDays} {tour.durationDays === 1 ? 'day' : 'days'}
      </span>
    </div>
  </div>
</article>
