---
interface Props {
  images: string[];
  tourName?: string;
}

const { images, tourName = 'Tour' } = Astro.props;

// Deduplicate and remove empty strings, cap at 5
const valid = [...new Set(images.filter(Boolean))].slice(0, 5);
const count = valid.length;
---

{count >= 2 && (
  <div class={`bento bento-${count}`}>
    {valid.map((src, i) => (
      <div class={`bento-cell bento-cell-${i + 1} overflow-hidden group`}>
        <img
          src={src}
          alt={`${tourName} – photo ${i + 1}`}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading={i === 0 ? 'eager' : 'lazy'}
          onerror="this.onerror=null;this.src='/assets/images/placeholders/default-tour.webp'"
        />
      </div>
    ))}
  </div>
)}

<style>
  .bento {
    display: grid;
    gap: 6px;
    border-radius: 16px;
    overflow: hidden;
    height: 460px;
  }

  .bento-cell {
    overflow: hidden;
    background: #e2e8f0;
  }

  /* ── 2 images: equal columns ── */
  .bento-2 {
    grid-template-columns: 1fr 1fr;
  }

  /* ── 3 images: large left + 2 stacked right ── */
  .bento-3 {
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .bento-3 .bento-cell-1 { grid-row: 1 / 3; }
  .bento-3 .bento-cell-2 { grid-row: 1; }
  .bento-3 .bento-cell-3 { grid-row: 2; }

  /* ── 4 images: large left (2 rows) + 2 stacked right + wide bottom strip ── */
  .bento-4 {
    grid-template-columns: 3fr 2fr;
    grid-template-rows: 1fr 1fr 1.3fr;
  }
  .bento-4 .bento-cell-1 { grid-column: 1; grid-row: 1 / 3; }
  .bento-4 .bento-cell-2 { grid-column: 2; grid-row: 1; }
  .bento-4 .bento-cell-3 { grid-column: 2; grid-row: 2; }
  .bento-4 .bento-cell-4 { grid-column: 1 / 3; grid-row: 3; }

  /* ── 5 images: tall left + 2×2 right ── */
  .bento-5 {
    grid-template-columns: 2fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .bento-5 .bento-cell-1 { grid-column: 1; grid-row: 1 / 3; }
  .bento-5 .bento-cell-2 { grid-column: 2; grid-row: 1; }
  .bento-5 .bento-cell-3 { grid-column: 3; grid-row: 1; }
  .bento-5 .bento-cell-4 { grid-column: 2; grid-row: 2; }
  .bento-5 .bento-cell-5 { grid-column: 3; grid-row: 2; }

  /* Mobile: stack vertically */
  @media (max-width: 640px) {
    .bento {
      height: auto;
      grid-template-columns: 1fr !important;
      grid-template-rows: auto !important;
    }
    .bento-cell {
      grid-column: auto !important;
      grid-row: auto !important;
      aspect-ratio: 16 / 9;
    }
  }
</style>
