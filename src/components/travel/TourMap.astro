---
import type { MapStop } from '@lib/types/view-models';

interface Props {
  stops: MapStop[];
  tourName?: string;
}

const { stops, tourName = 'Tour Route' } = Astro.props;
const validStops = stops.filter((s) => s.lat !== 0 && s.lng !== 0);

const width = 960;
const height = 520;
const paddingX = 88;
const paddingY = 70;

const lats = validStops.map((stop) => stop.lat);
const lngs = validStops.map((stop) => stop.lng);

const minLat = lats.length ? Math.min(...lats) : 0;
const maxLat = lats.length ? Math.max(...lats) : 0;
const minLng = lngs.length ? Math.min(...lngs) : 0;
const maxLng = lngs.length ? Math.max(...lngs) : 0;

const latRange = Math.max(maxLat - minLat, 0.8);
const lngRange = Math.max(maxLng - minLng, 0.8);

const project = (stop: MapStop) => {
  const x = paddingX + ((stop.lng - minLng) / lngRange) * (width - paddingX * 2);
  const y = paddingY + (1 - (stop.lat - minLat) / latRange) * (height - paddingY * 2);
  return {
    ...stop,
    x: Number(x.toFixed(2)),
    y: Number(y.toFixed(2)),
  };
};

const plottedStops = validStops.map(project);
const polylinePoints = plottedStops.map((stop) => `${stop.x},${stop.y}`).join(' ');
const provinceSummary = [...new Set(plottedStops.map((stop) => stop.province).filter(Boolean))];
const categorySummary = [...new Set(plottedStops.map((stop) => stop.category).filter(Boolean))];
---

{plottedStops.length > 0 ? (
  <div class="overflow-hidden rounded-[28px] border border-[#1e3a5f]/10 bg-white shadow-[0_14px_40px_rgba(15,23,42,0.08)]">
    <div class="border-b border-[#1e3a5f]/10 bg-[linear-gradient(135deg,#1e3a5f_0%,#244a72_48%,#2c5f8b_100%)] px-6 py-5 text-white sm:px-8">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#d9c08a]">Tour Map</p>
          <h3 class="mt-2 font-display text-2xl font-semibold leading-tight">Static route overview for {tourName}</h3>
          <p class="mt-2 max-w-2xl text-sm text-white/80">
            This map is rendered directly in HTML and SVG, so it works without JavaScript or third-party embeds.
          </p>
        </div>

        <dl class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-3">
          <div class="rounded-2xl bg-white/10 px-4 py-3 backdrop-blur-sm">
            <dt class="text-[11px] uppercase tracking-[0.18em] text-white/60">Stops</dt>
            <dd class="mt-1 text-lg font-semibold text-white">{plottedStops.length}</dd>
          </div>
          <div class="rounded-2xl bg-white/10 px-4 py-3 backdrop-blur-sm">
            <dt class="text-[11px] uppercase tracking-[0.18em] text-white/60">Provinces</dt>
            <dd class="mt-1 text-lg font-semibold text-white">{provinceSummary.length}</dd>
          </div>
          <div class="rounded-2xl bg-white/10 px-4 py-3 backdrop-blur-sm col-span-2 sm:col-span-1">
            <dt class="text-[11px] uppercase tracking-[0.18em] text-white/60">Journey</dt>
            <dd class="mt-1 text-lg font-semibold text-white">Day-by-day</dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="grid gap-0 lg:grid-cols-[minmax(0,1.6fr)_minmax(280px,0.9fr)]">
      <div class="border-b border-[#1e3a5f]/10 bg-[radial-gradient(circle_at_top,_rgba(184,138,42,0.12),_transparent_35%),linear-gradient(180deg,#f8fafc_0%,#eef4fb_100%)] p-4 sm:p-6 lg:border-b-0 lg:border-r">
        <div class="overflow-hidden rounded-[24px] border border-white/60 bg-white/55 shadow-inner shadow-[#1e3a5f]/5 backdrop-blur-sm">
          <svg
            viewBox={`0 0 ${width} ${height}`}
            class="h-auto w-full"
            role="img"
            aria-label={`Static route map showing ${plottedStops.length} stops for ${tourName}`}
          >
            <defs>
              <linearGradient id="route-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#1f4aa8"></stop>
                <stop offset="100%" stop-color="#b88a2a"></stop>
              </linearGradient>
              <filter id="stop-shadow" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="8" stdDeviation="8" flood-color="#1e3a5f" flood-opacity="0.18" />
              </filter>
            </defs>

            <rect x="0" y="0" width={width} height={height} fill="transparent"></rect>

            {[0.2, 0.4, 0.6, 0.8].map((ratio) => (
              <Fragment>
                <line
                  x1={paddingX}
                  y1={paddingY + ratio * (height - paddingY * 2)}
                  x2={width - paddingX}
                  y2={paddingY + ratio * (height - paddingY * 2)}
                  stroke="rgba(30,58,95,0.08)"
                  stroke-width="2"
                  stroke-dasharray="8 12"
                ></line>
                <line
                  x1={paddingX + ratio * (width - paddingX * 2)}
                  y1={paddingY}
                  x2={paddingX + ratio * (width - paddingX * 2)}
                  y2={height - paddingY}
                  stroke="rgba(30,58,95,0.08)"
                  stroke-width="2"
                  stroke-dasharray="8 12"
                ></line>
              </Fragment>
            ))}

            <rect
              x={paddingX}
              y={paddingY}
              width={width - paddingX * 2}
              height={height - paddingY * 2}
              rx="30"
              fill="rgba(255,255,255,0.7)"
              stroke="rgba(30,58,95,0.12)"
              stroke-width="2"
            ></rect>

            {polylinePoints && (
              <polyline
                points={polylinePoints}
                fill="none"
                stroke="url(#route-gradient)"
                stroke-width="8"
                stroke-linecap="round"
                stroke-linejoin="round"
                opacity="0.9"
              ></polyline>
            )}

            {plottedStops.map((stop, index) => (
              <Fragment>
                <circle
                  cx={stop.x}
                  cy={stop.y}
                  r="18"
                  fill="#1f4aa8"
                  stroke="#ffffff"
                  stroke-width="5"
                  filter="url(#stop-shadow)"
                ></circle>
                <text
                  x={stop.x}
                  y={stop.y + 1}
                  text-anchor="middle"
                  dominant-baseline="middle"
                  font-size="13"
                  font-weight="700"
                  fill="#ffffff"
                >
                  {stop.stopNumber}
                </text>
                <text
                  x={stop.x}
                  y={stop.y - 30 - (index % 2 === 0 ? 0 : 18)}
                  text-anchor="middle"
                  font-size="12"
                  font-weight="700"
                  fill="#1e3a5f"
                >
                  {stop.name}
                </text>
                <text
                  x={stop.x}
                  y={stop.y - 14 - (index % 2 === 0 ? 0 : 18)}
                  text-anchor="middle"
                  font-size="10"
                  letter-spacing="0.12em"
                  fill="rgba(30,58,95,0.72)"
                >
                  DAY {stop.dayNumber}
                </text>
              </Fragment>
            ))}

            <text x={paddingX} y="36" font-size="13" font-weight="700" fill="#1e3a5f">
              Route overview
            </text>
            <text x={paddingX} y="54" font-size="11" fill="rgba(30,58,95,0.62)">
              Coordinates are positioned from itinerary stop latitude and longitude.
            </text>
          </svg>
        </div>
      </div>

      <div class="bg-[#f8fafc] p-6 sm:p-8">
        <div class="flex flex-wrap gap-2">
          {provinceSummary.map((province) => (
            <span class="rounded-full bg-[#1f4aa8]/8 px-3 py-1 text-xs font-medium text-[#1e3a5f]">
              {province}
            </span>
          ))}
        </div>

        {categorySummary.length > 0 && (
          <p class="mt-4 text-sm text-[rgba(15,23,42,0.58)]">
            Highlights include {categorySummary.join(', ').toLowerCase()}.
          </p>
        )}

        <ol class="mt-6 space-y-3">
          {plottedStops.map((stop) => (
            <li class="rounded-2xl border border-[#1e3a5f]/10 bg-white p-4 shadow-sm">
              <div class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#1f4aa8] text-sm font-bold text-white">
                  {stop.stopNumber}
                </span>
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                    <p class="font-semibold text-[#1e3a5f]">{stop.name}</p>
                    <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[#b88a2a]">
                      Day {stop.dayNumber}
                    </span>
                  </div>
                  <p class="mt-1 text-xs text-[rgba(15,23,42,0.5)]">
                    {stop.province} · {stop.category}
                  </p>
                  {stop.descShort && (
                    <p class="mt-2 text-sm leading-relaxed text-[rgba(15,23,42,0.7)]">{stop.descShort}</p>
                  )}
                  <a
                    href={`/attractions/${stop.slug}`}
                    class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-[#1f4aa8] transition hover:text-[#16397f]"
                  >
                    View attraction
                    <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
) : (
  <div class="flex h-32 w-full items-center justify-center rounded-2xl border border-[#1e3a5f]/10 bg-[#1e3a5f]/5 text-sm italic text-[rgba(15,23,42,0.45)]">
    Map not available for this tour.
  </div>
)}
