---
import type { MapStop } from '@lib/types/view-models';

interface Props {
  stops: MapStop[];
  tourName?: string;
}

const { stops, tourName = 'Tour Route' } = Astro.props;
const mapId = 'tour-map';
const validStops = stops.filter((s) => s.lat !== 0 && s.lng !== 0);
const stopsData = JSON.stringify(validStops);
---

{validStops.length > 0 ? (
  <div class="relative w-full">
    <div
      id={mapId}
      class="w-full rounded-2xl shadow-md overflow-hidden"
      style="height: 420px; z-index: 0;"
      aria-label={`Map showing the route for ${tourName}`}
    ></div>
  </div>
) : (
  <div class="w-full h-32 rounded-2xl bg-[#1e3a5f]/5 border border-[#1e3a5f]/10 flex items-center justify-center text-sm text-[rgba(15,23,42,0.45)] italic">
    Map not available for this tour.
  </div>
)}

<script is:inline define:vars={{ mapId, stopsData, tourName }}>
(function () {
  if (!stopsData) return;
  var stops;
  try { stops = JSON.parse(stopsData); } catch (e) { return; }
  if (!stops || stops.length === 0) return;

  /* Dynamically load Leaflet CSS then JS with SRI integrity verification, then init map.
     The integrity and crossOrigin attributes are set so the browser enforces SRI. */
  var cssLink = document.createElement('link');
  cssLink.rel = 'stylesheet';
  cssLink.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
  cssLink.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
  cssLink.crossOrigin = 'anonymous';
  document.head.appendChild(cssLink);

  var jsScript = document.createElement('script');
  jsScript.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  jsScript.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLnA=';
  jsScript.crossOrigin = 'anonymous';
  jsScript.onload = function () { initMap(); };
  document.head.appendChild(jsScript);

  function initMap() {
    var container = document.getElementById(mapId);
    if (!container) return;

    var map = L.map(mapId, { scrollWheelZoom: false });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18,
    }).addTo(map);

    var latlngs = stops.map(function (s) { return [s.lat, s.lng]; });

    /* Polyline connecting stops */
    L.polyline(latlngs, { color: '#1f4aa8', weight: 2.5, opacity: 0.65, dashArray: '6 4' }).addTo(map);

    /* Numbered markers */
    stops.forEach(function (stop) {
      var icon = L.divIcon({
        className: '',
        html:
          '<div style="width:28px;height:28px;border-radius:50%;background:#1f4aa8;border:2.5px solid #fff;' +
          'box-shadow:0 2px 6px rgba(0,0,0,0.35);display:flex;align-items:center;justify-content:center;' +
          'color:#fff;font-size:11px;font-weight:700;font-family:sans-serif;">' +
          stop.stopNumber +
          '</div>',
        iconSize: [28, 28],
        iconAnchor: [14, 14],
        popupAnchor: [0, -16],
      });

      var popupHtml =
        '<div style="font-family:sans-serif;min-width:200px;max-width:240px;">' +
        '<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#b88a2a;margin-bottom:2px;">Stop ' + stop.stopNumber + ' &mdash; Day ' + stop.dayNumber + '</div>' +
        '<div style="font-size:14px;font-weight:700;color:#1e3a5f;margin-bottom:4px;">' + stop.name + '</div>' +
        '<div style="font-size:11px;color:#555;margin-bottom:2px;">' +
          '<span style="margin-right:8px;">&#127759; ' + stop.province + '</span>' +
          '<span>&#127968; ' + stop.category + '</span>' +
        '</div>' +
        (stop.descShort ? '<p style="font-size:12px;color:#333;margin:6px 0 8px;">' + stop.descShort + '</p>' : '') +
        '<a href="/attractions/' + stop.slug + '" style="font-size:12px;font-weight:600;color:#1f4aa8;text-decoration:underline;">View Attraction &rarr;</a>' +
        '</div>';

      L.marker([stop.lat, stop.lng], { icon: icon })
        .addTo(map)
        .bindPopup(popupHtml, { maxWidth: 260 });
    });

    /* Fit map bounds with padding */
    var group = L.featureGroup(stops.map(function (s) { return L.marker([s.lat, s.lng]); }));
    map.fitBounds(group.getBounds().pad(0.25));
  }
})();
</script>
