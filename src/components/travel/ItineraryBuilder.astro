---
/**
 * ItineraryBuilder.astro
 *
 * Interactive itinerary builder that runs fully client-side.
 * All CSV-derived data is embedded at build time as a JSON payload;
 * no server, API route, or runtime filesystem access is required.
 *
 * Pricing is labelled "Estimated" per Pricing-Policy.md.
 * When route logic or pricing cannot be resolved confidently,
 * the component surfaces "Custom Quote Required" instead of failing.
 */

import type { ClientAttraction, ClientRouteLeg, ClientLocation, ClientHotelRates } from '@lib/engine/client-engine';
import { siteConfig } from '@lib/config';

interface Props {
  attractions: ClientAttraction[];
  routeMatrix: ClientRouteLeg[];
  locations: ClientLocation[];
  hotelNightlyRates: ClientHotelRates;
}

const { attractions, routeMatrix, locations, hotelNightlyRates } = Astro.props;

// Serialise all data for the client-side script
const engineData = JSON.stringify({ attractions, routeMatrix, locations, hotelNightlyRates });

// Group attractions by region for the form checkboxes
const byRegion = attractions.reduce<Record<string, ClientAttraction[]>>((acc, a) => {
  const key = a.region || a.province || 'Other';
  (acc[key] ??= []).push(a);
  return acc;
}, {});
const regions = Object.entries(byRegion).sort(([a], [b]) => a.localeCompare(b));

const whatsappUrl = siteConfig.whatsapp.url;
const contactEmail = siteConfig.email;
---

<!-- Embedded data for the client engine -->
<script type="application/json" id="itinerary-engine-data" set:html={engineData}></script>

<section class="py-16 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <div class="mb-10 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-[#b88a2a] mb-2">Plan Your Journey</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-[#1e3a5f] mb-3">Build Your Itinerary</h2>
      <p class="text-sm text-[rgba(15,23,42,0.6)] max-w-xl mx-auto leading-relaxed">
        Select the places you want to visit, set your group and accommodation preferences,
        and receive an estimated day-by-day itinerary and pricing in seconds.
      </p>
    </div>

    <!-- Form -->
    <form id="itinerary-form" class="space-y-8" novalidate>

      <!-- Attraction selector -->
      <div>
        <h3 class="text-sm font-semibold text-[#1e3a5f] uppercase tracking-wider mb-4">
          Attractions to Visit
          <span class="normal-case font-normal text-[rgba(15,23,42,0.5)] ml-1">(select at least one)</span>
        </h3>
        <div id="attraction-list" class="space-y-6">
          {regions.map(([region, atts]) => (
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-[#b88a2a] mb-3">{region}</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {atts.map(a => (
                  <label class="flex items-start gap-3 p-3 rounded-xl border border-gray-200 cursor-pointer hover:border-[#1e3a5f] hover:bg-[#f6f7fb] transition-colors duration-150 has-[:checked]:border-[#1e3a5f] has-[:checked]:bg-[#f0f4fa]">
                    <input
                      type="checkbox"
                      name="attractions"
                      value={a.attractionCode}
                      class="mt-0.5 accent-[#1e3a5f] shrink-0"
                    />
                    <span class="text-sm leading-snug">
                      <span class="font-medium text-[#1e3a5f]">{a.name}</span>
                      <span class="block text-xs text-[rgba(15,23,42,0.5)] mt-0.5">{a.province} · {a.category}</span>
                    </span>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p id="attractions-error" class="hidden text-xs text-red-500 mt-2">Please select at least one attraction.</p>
      </div>

      <!-- Trip settings -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

        <!-- Group size -->
        <div>
          <label for="group-size" class="block text-sm font-semibold text-[#1e3a5f] mb-2">
            Group Size
          </label>
          <input
            type="number"
            id="group-size"
            name="groupSize"
            min="1"
            max="40"
            value="2"
            class="w-full rounded-xl border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:border-[#1e3a5f] focus:ring-1 focus:ring-[#1e3a5f]"
          />
        </div>

        <!-- Accommodation level -->
        <div>
          <label for="hotel-tier" class="block text-sm font-semibold text-[#1e3a5f] mb-2">
            Accommodation
          </label>
          <select
            id="hotel-tier"
            name="hotelTier"
            class="w-full rounded-xl border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:border-[#1e3a5f] focus:ring-1 focus:ring-[#1e3a5f]"
          >
            <option value="budget">Budget</option>
            <option value="comfort" selected>Standard</option>
            <option value="premium">Premium</option>
          </select>
        </div>

        <!-- Vehicle type -->
        <div>
          <label for="vehicle-type" class="block text-sm font-semibold text-[#1e3a5f] mb-2">
            Vehicle
          </label>
          <select
            id="vehicle-type"
            name="vehicleType"
            class="w-full rounded-xl border border-gray-300 px-4 py-2.5 text-sm focus:outline-none focus:border-[#1e3a5f] focus:ring-1 focus:ring-[#1e3a5f]"
          >
            <option value="sedan">Private Sedan (1–3 pax)</option>
            <option value="prado" selected>4×4 SUV (1–3 pax)</option>
            <option value="hiace">Van (4–8 pax)</option>
            <option value="coaster">Large Van (9+ pax)</option>
          </select>
        </div>

      </div>

      <!-- Submit -->
      <div class="text-center">
        <button
          type="submit"
          id="build-btn"
          class="inline-flex items-center gap-2 px-10 py-4 rounded-full bg-[#1e3a5f] hover:bg-[#162d4a] text-white font-semibold text-sm shadow-md transition-all duration-200 disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <span id="build-btn-label">Build My Itinerary</span>
          <svg id="build-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
        </button>
      </div>

    </form>

    <!-- Results area -->
    <div id="itinerary-results" class="mt-12 hidden"></div>

  </div>
</section>

<script>
  import { runClientEngine } from '@lib/engine/client-engine';
  import type { ClientData, ClientItineraryResult } from '@lib/engine/client-engine';

  // ── Load embedded data ──────────────────────────────────────────────────────
  const dataEl = document.getElementById('itinerary-engine-data') as HTMLScriptElement | null;
  const engineData: ClientData | null = dataEl ? JSON.parse(dataEl.textContent ?? '{}') : null;

  // ── DOM refs ────────────────────────────────────────────────────────────────
  const form = document.getElementById('itinerary-form') as HTMLFormElement;
  const resultsDiv = document.getElementById('itinerary-results') as HTMLDivElement;
  const buildBtn = document.getElementById('build-btn') as HTMLButtonElement;
  const buildBtnLabel = document.getElementById('build-btn-label') as HTMLSpanElement;
  const buildSpinner = document.getElementById('build-spinner') as SVGElement;
  const attractionsError = document.getElementById('attractions-error') as HTMLParagraphElement;

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function setLoading(loading: boolean) {
    buildBtn.disabled = loading;
    buildBtnLabel.textContent = loading ? 'Building…' : 'Build My Itinerary';
    buildSpinner.classList.toggle('hidden', !loading);
  }

  function minutesToHours(mins: number): string {
    const h = Math.floor(mins / 60);
    const m = mins % 60;
    if (h === 0) return `${m}m`;
    return m === 0 ? `${h}h` : `${h}h ${m}m`;
  }

  function usd(n: number): string {
    return `$${n.toLocaleString('en-US')}`;
  }

  // ── Render success ───────────────────────────────────────────────────────────
  function renderResult(result: ClientItineraryResult) {
    const { days, pricing, summary } = result;

    const dayCards = days.map(day => {
      const stopList = day.stops.length > 0
        ? `<ul class="mt-3 space-y-1">
            ${day.stops.map(s =>
              `<li class="flex items-start gap-2 text-sm text-[rgba(15,23,42,0.75)]">
                <span class="mt-1 shrink-0 w-1.5 h-1.5 rounded-full bg-[#b88a2a]"></span>
                <span><strong>${s.name}</strong> <span class="text-xs text-[rgba(15,23,42,0.45)]">${s.category} · ${minutesToHours(s.visitMinutes)}</span></span>
              </li>`
            ).join('')}
           </ul>`
        : '';

      const driveNote = day.driveMinutes > 0
        ? `<p class="mt-2 text-xs text-[rgba(15,23,42,0.5)]">🚗 Driving: ${minutesToHours(day.driveMinutes)}</p>`
        : '';

      const typeBadge = day.type === 'transit'
        ? `<span class="ml-2 text-[10px] font-semibold uppercase tracking-wider bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full">Transit Day</span>`
        : '';

      return `
        <div class="rounded-2xl border border-gray-200 p-5 bg-white shadow-sm">
          <div class="flex items-baseline gap-2 mb-1">
            <span class="text-xs font-bold text-[#b88a2a] uppercase tracking-widest">Day ${day.dayNumber}</span>
            ${typeBadge}
          </div>
          <p class="font-semibold text-[#1e3a5f]">Overnight: ${day.overnightName || day.overnight}</p>
          ${stopList}
          ${driveNote}
        </div>`;
    }).join('');

    const pricingRows = [
      ['Vehicle', usd(pricing.vehicleCost)],
      ['Accommodation', usd(pricing.hotelCost)],
      ['Local Guide', usd(pricing.guideCost)],
      ['Meals', usd(pricing.mealCost)],
      ['Fuel', usd(pricing.fuelCost)],
      ['Subtotal', usd(pricing.subtotal)],
      [`Service & margin (${Math.round((pricing.markup / pricing.subtotal) * 100)}%)`, usd(pricing.markup)],
    ].map(([label, value]) =>
      `<tr class="border-t border-gray-100">
         <td class="py-2 pr-4 text-sm text-[rgba(15,23,42,0.65)]">${label}</td>
         <td class="py-2 text-sm text-right font-medium text-[#1e3a5f]">${value}</td>
       </tr>`
    ).join('');

    resultsDiv.innerHTML = `
      <div class="space-y-8">

        <!-- Summary strip -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          ${[
            ['Total Days', summary.totalDays],
            ['Touring Days', summary.touringDays],
            ['Overnights', summary.overnights],
            ['Attractions', summary.totalAttractions],
          ].map(([label, val]) =>
            `<div class="rounded-2xl bg-[#f6f7fb] px-5 py-4 text-center">
               <p class="text-2xl font-bold text-[#1e3a5f]">${val}</p>
               <p class="text-xs text-[rgba(15,23,42,0.5)] mt-1">${label}</p>
             </div>`
          ).join('')}
        </div>

        <!-- Day-by-day -->
        <div>
          <h3 class="font-display text-xl font-bold text-[#1e3a5f] mb-4">Day-by-Day Itinerary</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">${dayCards}</div>
        </div>

        <!-- Pricing -->
        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <h3 class="font-display text-xl font-bold text-[#1e3a5f] mb-1">Estimated Pricing</h3>
          <p class="text-xs text-[rgba(15,23,42,0.5)] mb-5">
            Indicative estimate based on selected preferences.
            Final price confirmed on booking.
          </p>
          <table class="w-full">
            <tbody>${pricingRows}</tbody>
            <tfoot>
              <tr class="border-t-2 border-[#1e3a5f]">
                <td class="pt-3 pr-4 text-sm font-bold text-[#1e3a5f]">Estimated Total</td>
                <td class="pt-3 text-right text-lg font-bold text-[#1e3a5f]">${usd(pricing.total)}</td>
              </tr>
              <tr>
                <td class="pt-1 text-xs text-[rgba(15,23,42,0.5)]">Per person (${summary.totalAttractions > 0 ? 'group' : '—'})</td>
                <td class="pt-1 text-right text-sm font-semibold text-[#b88a2a]">${usd(pricing.perPax)} / pax</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- CTA -->
        <div class="rounded-2xl bg-[#1e3a5f] px-6 py-8 text-center text-white">
          <p class="font-display text-xl font-bold mb-2">Ready to book?</p>
          <p class="text-white/70 text-sm mb-6 max-w-md mx-auto">
            Send us this itinerary and we will confirm availability, refine the plan,
            and provide a final quote tailored to your group.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="https://wa.me/0093780123456"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full bg-[#25d366] hover:bg-[#1da851] text-white font-semibold text-sm transition-colors duration-150"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Us
            </a>
            <a
              href="mailto:info@afghantours.com"
              class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full border border-white/30 hover:bg-white/10 text-white font-semibold text-sm transition-colors duration-150"
            >
              Email Us
            </a>
          </div>
        </div>

      </div>`;

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Render custom quote required ─────────────────────────────────────────────
  function renderCustomQuote(reason?: string) {
    const reasonNote = reason
      ? `<p class="text-sm text-[rgba(15,23,42,0.6)] mb-6 max-w-md mx-auto">${reason}</p>`
      : '';

    resultsDiv.innerHTML = `
      <div class="rounded-2xl border-2 border-[#b88a2a] bg-[#fffbf2] px-6 py-10 text-center">
        <p class="text-[#b88a2a] font-bold text-xl mb-2">Custom Quote Required</p>
        ${reasonNote}
        <p class="text-sm text-[rgba(15,23,42,0.65)] mb-6 max-w-md mx-auto">
          Your selected combination involves routing or logistics that require
          specialist planning. Contact us and we will build a tailored itinerary
          for your group.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="https://wa.me/0093780123456"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full bg-[#25d366] hover:bg-[#1da851] text-white font-semibold text-sm transition-colors duration-150"
          >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
          <a
            href="mailto:info@afghantours.com"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full border border-[#b88a2a] text-[#b88a2a] hover:bg-[#b88a2a] hover:text-white font-semibold text-sm transition-colors duration-150"
          >
            Email Us
          </a>
        </div>
      </div>`;

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Form submit handler ──────────────────────────────────────────────────────
  form.addEventListener('submit', (e) => {
    e.preventDefault();

    // Validate attractions
    const checkedBoxes = Array.from(
      form.querySelectorAll<HTMLInputElement>('input[name="attractions"]:checked')
    );
    if (checkedBoxes.length === 0) {
      attractionsError.classList.remove('hidden');
      return;
    }
    attractionsError.classList.add('hidden');

    const attractionCodes = checkedBoxes.map((cb) => cb.value);
    const groupSize = parseInt((form.querySelector<HTMLInputElement>('#group-size'))?.value ?? '1', 10);
    const hotelTier = (form.querySelector<HTMLSelectElement>('#hotel-tier'))?.value as 'budget' | 'comfort' | 'premium';
    const vehicleType = (form.querySelector<HTMLSelectElement>('#vehicle-type'))?.value as 'sedan' | 'prado' | 'hiace' | 'coaster';

    if (!engineData) {
      renderCustomQuote('Engine data could not be loaded. Please try refreshing the page.');
      return;
    }

    setLoading(true);

    // Use setTimeout to let the browser paint the loading state before running
    setTimeout(() => {
      const engineResult = runClientEngine(engineData, {
        attractionCodes,
        groupSize,
        hotelTier,
        vehicleType,
      });

      setLoading(false);

      if (engineResult.ok) {
        renderResult(engineResult.result);
      } else {
        renderCustomQuote(engineResult.reason);
      }
    }, 50);
  });
</script>
