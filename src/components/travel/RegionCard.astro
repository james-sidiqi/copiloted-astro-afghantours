---
import SafeImage from '@components/ui/SafeImage.astro';

interface Props {
  region: import('@lib/types/view-models').Region;
}
const { region } = Astro.props;
---

<article class="group bg-white rounded-[18px] shadow-[0_2px_16px_0_rgba(0,0,0,0.08)] hover:shadow-[0_10px_30px_rgba(15,23,42,0.08)] transition-shadow duration-300 overflow-hidden flex flex-col">
  <!-- Image -->
  <a href={`/regions/${region.regionSlug}`} class="block overflow-hidden aspect-[16/9] bg-gray-100 shrink-0">
    <SafeImage
      src={region.imgPath}
      fallback="/assets/images/placeholders/default-region.webp"
      alt={region.regionName}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </a>

  <!-- Body -->
  <div class="flex flex-col flex-1 p-5 gap-2">
    <a href={`/regions/${region.regionSlug}`} class="block">
      <h3 class="font-display text-lg font-semibold text-[#1e3a5f] leading-snug group-hover:text-[#1f4aa8] transition-colors duration-150">
        {region.regionName}
      </h3>
    </a>

    {region.description && (
      <p class="text-sm text-[rgba(15,23,42,0.7)] leading-relaxed line-clamp-3 flex-1">
        {region.description}
      </p>
    )}

    <a
      href={`/regions/${region.regionSlug}`}
      class="self-start mt-2 text-sm font-medium text-[#1f4aa8] hover:text-[#1e3a5f] flex items-center gap-1 transition-colors duration-150"
    >
      Explore region
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
