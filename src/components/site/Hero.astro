---
interface Props {
  title: string;
  subtitle?: string;
  imagePath?: string;
  ctaText?: string;
  ctaHref?: string;
}
const { title, subtitle, imagePath, ctaText, ctaHref } = Astro.props;
---

<section
  class="relative w-full min-h-[560px] flex items-center justify-center overflow-hidden bg-[#1e3a5f]"
>
  <!-- Background image -->
  {imagePath && (
    <img
      src={imagePath}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
    />
  )}

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#0f172a]/60 via-[#0f172a]/50 to-[#0f172a]/70"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center text-white py-16">
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight drop-shadow-sm">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-5 text-lg sm:text-xl text-white/85 max-w-xl mx-auto leading-relaxed">
        {subtitle}
      </p>
    )}

    {ctaText && ctaHref && (
      <a
        href={ctaHref}
        class="inline-block mt-8 px-8 py-3.5 rounded-full bg-[#b88a2a] hover:bg-[#a07820] text-white font-semibold text-base shadow-lg hover:shadow-xl transition-all duration-200 focus:outline-none focus:ring-4 focus:ring-[#b88a2a]/50"
      >
        {ctaText}
      </a>
    )}
  </div>
</section>
