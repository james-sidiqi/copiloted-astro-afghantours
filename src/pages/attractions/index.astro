---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/site/Hero.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import AttractionCard from '@components/travel/AttractionCard.astro';
import { buildSiteData } from '@lib/data/buildRelations';

const data = buildSiteData();
const attractions = data.attractions.filter(a => a.isActive);
const categories = [...new Set(attractions.map(a => a.category).filter(Boolean))].sort();
---

<BaseLayout title="Attractions – Afghan Tours" description="Discover Afghanistan's iconic attractions, from ancient ruins to stunning natural landscapes.">
  <Hero
    title="Discover Afghanistan's Attractions"
    subtitle="Ancient cities, dramatic landscapes, and cultural treasures await"
    imagePath="/assets/images/heroes/hero-destinations.webp"
    ctaText="Plan Your Visit"
    ctaHref="/contact"
  />

  <section class="py-20 bg-[#f6f7fb]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="mb-10">
        <SectionHeader
          eyebrow="Attractions"
          title="Explore the Highlights"
          subtitle="Afghanistan is home to some of the world's most remarkable and least-visited wonders."
        />
        {categories.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {categories.map(cat => (
              <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-white border border-gray-200 text-[#1e3a5f] shadow-sm">
                {cat}
              </span>
            ))}
          </div>
        )}
      </div>

      {attractions.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
          {attractions.map(attraction => <AttractionCard attraction={attraction} />)}
        </div>
      ) : (
        <div class="text-center py-20 text-gray-500">
          <p class="text-lg font-medium">No attractions available at this time.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
