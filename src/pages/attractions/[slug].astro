---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/site/Hero.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import TourCard from '@components/travel/TourCard.astro';
import type { Attraction } from '@lib/types/view-models';
import { buildSiteData } from '@lib/data/buildRelations';

export async function getStaticPaths() {
  const data = buildSiteData();
  return data.attractions.filter(a => a.isActive).map(a => ({
    params: { slug: a.slug },
    props: { attraction: a, allTours: data.tours.filter(t => t.isActive) },
  }));
}

interface Props {
  attraction: Attraction;
  allTours: import('@lib/types/view-models').Tour[];
}
const { attraction, allTours } = Astro.props;

const relatedTours = allTours.filter(t =>
  t.attractions.some(a => a.attractionCode === attraction.attractionCode)
);
---

<BaseLayout title={`${attraction.name} – Afghan Tours`} description={attraction.descShort}>
  <!-- Full-width image -->
  <div class="relative w-full h-[50vh] min-h-[320px] bg-[#1e3a5f] overflow-hidden">
    {attraction.imagePath ? (
      <img
        src={attraction.imagePath}
        alt={attraction.name}
        class="w-full h-full object-cover object-center"
        loading="eager"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-[#1e3a5f] to-[#1f4aa8]" />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a]/70 to-transparent" />
    <div class="absolute bottom-0 left-0 right-0 max-w-6xl mx-auto px-4 sm:px-6 pb-8">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        {attraction.category && (
          <span class="text-xs font-semibold px-3 py-1 rounded-full bg-[#b88a2a] text-white">
            {attraction.category}
          </span>
        )}
      </div>
      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight">
        {attraction.name}
      </h1>
      <p class="text-white/70 text-sm mt-2 flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        {attraction.province}{attraction.region ? `, ${attraction.region} Region` : ''}
      </p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-10">
        <!-- Description -->
        <section>
          <SectionHeader eyebrow="About" title={attraction.name} />
          {attraction.descLong ? (
            <p class="mt-4 text-[rgba(15,23,42,0.75)] leading-relaxed text-base">{attraction.descLong}</p>
          ) : attraction.descShort ? (
            <p class="mt-4 text-[rgba(15,23,42,0.75)] leading-relaxed text-base">{attraction.descShort}</p>
          ) : null}
        </section>

        <!-- Tags -->
        {attraction.tags.length > 0 && (
          <section>
            <h3 class="font-semibold text-[#1e3a5f] mb-3 text-sm uppercase tracking-wider">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {attraction.tags.map(tag => (
                <span class="text-xs font-medium px-3 py-1.5 rounded-full bg-[#f6f7fb] border border-gray-200 text-[rgba(15,23,42,0.7)]">
                  {tag}
                </span>
              ))}
            </div>
          </section>
        )}

        <!-- Related Tours -->
        {relatedTours.length > 0 && (
          <section>
            <div class="mb-6">
              <SectionHeader eyebrow="Tours" title="Tours Including This Attraction" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {relatedTours.slice(0, 4).map(tour => <TourCard tour={tour} />)}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="bg-white rounded-2xl shadow-[0_2px_20px_rgba(0,0,0,0.08)] p-6">
          <h3 class="font-semibold text-[#1e3a5f] mb-4 text-sm uppercase tracking-wider">Details</h3>
          <ul class="space-y-3 text-sm text-[rgba(15,23,42,0.75)]">
            {attraction.category && (
              <li class="flex justify-between">
                <span class="font-medium text-[#1e3a5f]">Category</span>
                <span>{attraction.category}</span>
              </li>
            )}
            {attraction.province && (
              <li class="flex justify-between">
                <span class="font-medium text-[#1e3a5f]">Province</span>
                <span>{attraction.province}</span>
              </li>
            )}
            {attraction.region && (
              <li class="flex justify-between">
                <span class="font-medium text-[#1e3a5f]">Region</span>
                <span>{attraction.region}</span>
              </li>
            )}
            {(attraction.latitude !== 0 || attraction.longitude !== 0) && (
              <li class="flex justify-between">
                <span class="font-medium text-[#1e3a5f]">Coordinates</span>
                <span class="text-xs">{attraction.latitude.toFixed(4)}, {attraction.longitude.toFixed(4)}</span>
              </li>
            )}
          </ul>
        </div>

        <div class="bg-[#1e3a5f] rounded-2xl p-6 text-white text-center">
          <p class="font-display text-lg font-bold mb-2">Visit on a Guided Tour</p>
          <p class="text-white/75 text-sm mb-4">We'll take care of all the logistics so you can focus on the experience.</p>
          <a href="/tours" class="block w-full text-center py-2.5 rounded-full bg-[#b88a2a] hover:bg-[#a07820] text-white font-semibold text-sm transition-all duration-200">
            Browse Tours
          </a>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
