---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/site/Hero.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
---

<BaseLayout title="Contact Us – Afghan Tours" description="Get in touch with Afghan Tours. We respond within 24 hours.">
  <Hero
    title="Contact Us"
    subtitle="We'd love to hear from you — get in touch and let's start planning"
    imagePath="/assets/images/heroes/hero-contact.webp"
  />

  <section class="py-20 bg-[#f6f7fb]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact info -->
        <div class="space-y-8">
          <div>
            <SectionHeader eyebrow="Get in Touch" title="We're Here to Help" />
            <p class="mt-4 text-[rgba(15,23,42,0.75)] leading-relaxed">
              Whether you have a question about safety, want to customise an itinerary, or are ready to book — our team is happy to chat. We typically respond within 24 hours.
            </p>
          </div>

          <div class="space-y-5">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-[#1e3a5f] flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[#1e3a5f] text-sm">Email</p>
                <a href="mailto:info@afghantours.com" class="text-[#1f4aa8] hover:underline text-sm">info@afghantours.com</a>
                <p class="text-xs text-[rgba(15,23,42,0.5)] mt-0.5">We respond within 24 hours</p>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-green-600 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[#1e3a5f] text-sm">WhatsApp</p>
                <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:underline text-sm">Chat on WhatsApp</a>
                <p class="text-xs text-[rgba(15,23,42,0.5)] mt-0.5">Quickest way to reach us</p>
              </div>
            </div>
          </div>

          <div class="bg-[#1e3a5f]/5 rounded-2xl p-5 border border-[#1e3a5f]/10">
            <p class="text-sm font-semibold text-[#1e3a5f] mb-1">Response Time</p>
            <p class="text-sm text-[rgba(15,23,42,0.7)]">We aim to respond to all enquiries within 24 hours. For urgent matters, WhatsApp is the fastest option.</p>
          </div>
        </div>

        <!-- Contact form -->
        <div class="bg-white rounded-2xl shadow-[0_2px_20px_rgba(0,0,0,0.08)] p-8">
          <h2 class="font-display text-xl font-bold text-[#1e3a5f] mb-6">Send Us a Message</h2>
          <form action="#" method="post" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-[#1e3a5f] mb-1.5">Your Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="John Smith"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-[#0f172a] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1f4aa8]/40 focus:border-[#1f4aa8] transition-all"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-[#1e3a5f] mb-1.5">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="john@example.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-[#0f172a] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1f4aa8]/40 focus:border-[#1f4aa8] transition-all"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-semibold text-[#1e3a5f] mb-1.5">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="Tour enquiry, custom itinerary, etc."
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-[#0f172a] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1f4aa8]/40 focus:border-[#1f4aa8] transition-all"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-[#1e3a5f] mb-1.5">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Tell us about your travel interests, preferred dates, group size..."
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-[#0f172a] placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#1f4aa8]/40 focus:border-[#1f4aa8] transition-all resize-y"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full py-3.5 rounded-full bg-[#b88a2a] hover:bg-[#a07820] text-white font-semibold text-sm shadow-md transition-all duration-200"
            >
              Send Message
            </button>
            <p class="text-xs text-center text-[rgba(15,23,42,0.5)]">We respond within 24 hours.</p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
